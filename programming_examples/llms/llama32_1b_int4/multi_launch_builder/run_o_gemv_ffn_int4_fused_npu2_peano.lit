// REQUIRES: ryzen_ai_npu2, peano
//
// RUN: mkdir -p test_o_gemv_ffn_int4_fused_npu2_peano
// RUN: cd test_o_gemv_ffn_int4_fused_npu2_peano
// RUN: make -f %S/Makefile_o_gemv_ffn_int4_fused clean
//
// Post-attention block of LLAMA-3.2-1B decode fused into one launch
// (O-proj + residual + RMSNorm + FFN gate/up + SwiGLU + FFN down +
// residual). Three herds (LA / LGU / LD) wired by two cascade chains;
// LD inner k-loop uses matvec_int4_bf16_packed_b_offset against a
// single L1 swiglu buffer so its PACKED gets standard L1 ping-pong.
// RUN: make -f %S/Makefile_o_gemv_ffn_int4_fused run PEANO_INSTALL_DIR=%PEANO_INSTALL_DIR | FileCheck %s
// CHECK: PASS!
